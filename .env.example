# Django (개발용)
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=1
# 폰 접속 시 노트북 IP 추가: localhost,127.0.0.1,0.0.0.0,192.168.0.10
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Email (미설정 시 콘솔 출력, 실제 발송하려면 SMTP 설정)
# --- Gmail 예시 (2단계인증 시 앱 비밀번호 사용) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD="비밀번호"  # 특수문자(*,# 등) 포함 시 따옴표 필수
# DEFAULT_FROM_EMAIL=your@gmail.com
#
# --- Naver 예시 ---
# EMAIL_HOST=smtp.naver.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_id@naver.com
#
# --- 다른 SMTP (Mailgun, SendGrid 등) ---
# 해당 서비스의 SMTP 호스트/포트 정보 입력

# DB (PostgreSQL)
DB_NAME=landinghelp
DB_USER=landinghelp
DB_PASSWORD=landinghelp
DB_HOST=db
DB_PORT=5432
