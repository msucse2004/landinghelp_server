# Django (개발용)
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=1
# 폰 접속 시 노트북 IP 추가: localhost,127.0.0.1,0.0.0.0,192.168.0.10
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Email / SMTP (실제 발송 시 환경변수로만 설정. 키/비밀번호는 코드·깃에 넣지 말 것)
# .env는 gitignore 대상이므로 로컬 .env에 넣거나, Docker는 호스트 환경변수로 전달.
# 확인: python manage.py check_email_env
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@yoursite.com
# SITE_URL=https://yoursite.com

# DeepL 번역 (메시지 함 등 UI 문구 번역). 키 없으면 해당 문구는 원문 표시.
# 값은 .env에 넣거나 시스템 환경변수로 설정 (코드/깃에 넣지 말 것)
# DEEPL_AUTH_KEY=your_deepl_api_key_here

# Ollama 후편집 (번역 파이프라인). 선택 사항. 미설정 시 DeepL 결과만 사용
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# DB (PostgreSQL)
DB_NAME=landinghelp
DB_USER=landinghelp
DB_PASSWORD=landinghelp
DB_HOST=db
DB_PORT=5432
