# Django (개발용)
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=1
# 폰 접속 시 노트북 IP 추가: localhost,127.0.0.1,0.0.0.0,192.168.0.10
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Email (미설정 시 콘솔 출력, 실제 발송하려면 SMTP 설정)
# EMAIL_HOST_USER, EMAIL_HOST_PASSWORD, DEFAULT_FROM_EMAIL는 .env에 두지 않고 시스템 환경변수로 설정 (보안)
# 예: export EMAIL_HOST_USER=your@naver.com
#     export EMAIL_HOST_PASSWORD=비밀번호
#     export DEFAULT_FROM_EMAIL=your@naver.com
#
# --- .env 예시 ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.naver.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true

# DeepL 번역 (메시지 함 등 UI 문구 번역). 키 없으면 해당 문구는 원문 표시
# DEEPL_AUTH_KEY=your_deepl_api_key_here

# DB (PostgreSQL)
DB_NAME=landinghelp
DB_USER=landinghelp
DB_PASSWORD=landinghelp
DB_HOST=db
DB_PORT=5432
